# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./prismrx.db
# Postgres (swap when ready)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prismrx

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_AUTH=false
ENABLE_VOICE=false
ENABLE_CHAT=false

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_SOURCE_DOCS=12
MAX_COMPARE_POLICIES=3

# ── Optional integrations (fill in if using Auth0/ElevenLabs) ─────────────────
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_SECRET=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

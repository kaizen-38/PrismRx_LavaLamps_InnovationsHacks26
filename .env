# PrismRx Backend Environment Variables
# Copy this to .env and update values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=prismrx_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prismrx_dev

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Auth0 (optional for hackathon MVP)
AUTH0_DOMAIN=dev-dtrkv2aqn3h4bopd.us.auth0.com
AUTH0_CLIENT_ID=GB7vmfn15VKzZPPAse6dT2clcytiCaIZ
AUTH0_CLIENT_SECRET=d5zo6CubzAgTTT206lkgahiH1ivDkvkVfm1Eq9AmeX0M9t2dXCr068RyujwD0v9z

# Google Cloud / Vertex AI (optional - for Gemini integration later)
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# Supabase (optional - using local Postgres for hackathon)
SUPABASE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=your_key

# PDF Storage and Parser
STORAGE_PATH=/data/policies
PDF_PARSER_TYPE=pymupdf
PRESERVE_FORMATTING=true
MIN_CHAR_LENGTH=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
